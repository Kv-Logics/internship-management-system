# ==============================================================================
# IMS APPLICATION ENVIRONMENT TEMPLATE (.env.example)
# Rename this file to '.env' and configure secure values before deploying.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# PostgreSQL credentials used to initialize the Docker Compose database container.
POSTGRES_USER=ims_admin
POSTGRES_PASSWORD=generate_a_secure_database_password
POSTGRES_DB=internship_management

# SQLAlchemy async connection URL.
# Note: Set host to "db" for Docker networks, or use database IP/Domain for standalone server.
DATABASE_URL=postgresql+asyncpg://ims_admin:generate_a_secure_database_password@db:5432/internship_management

# ------------------------------------------------------------------------------
# 2. SSO AUTHENTICATION INTEGRATION
# ------------------------------------------------------------------------------
# JWT keys used to verify login tokens signed by the central SSO server (nitt_auth).
# WARNING: These MUST match the JWT secret configuration of your deployed SSO node.
JWT_ACCESS_SECRET=paste_jwt_access_secret_from_sso_config
JWT_REFRESH_SECRET=paste_jwt_refresh_secret_from_sso_config

# ------------------------------------------------------------------------------
# 3. BACKEND CORE SECURITY
# ------------------------------------------------------------------------------
# Secret key used by the FastAPI backend for local signature operations.
# Run `openssl rand -hex 32` in your console to generate a secure random string.
SECRET_KEY=generate_a_random_32_byte_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------------------------
# 4. PRIMARY SYSTEM ADMINISTRATOR FALLBACK
# ------------------------------------------------------------------------------
# Fallback administrator credentials for backend command/auth operations.
ADMIN_USERNAME=114123003@nitt.edu
ADMIN_PASSWORD=generate_a_strong_fallback_admin_password

# ------------------------------------------------------------------------------
# 5. NETWORK URLs (CORS & Endpoints)
# ------------------------------------------------------------------------------
# FRONTEND_URL: Comma-separated origins allowed by the backend's CORS policies.
FRONTEND_URL=http://your-server-ip-or-domain:3000

# NEXT_PUBLIC_API_URL: Public REST API endpoint URL of the FastAPI backend.
NEXT_PUBLIC_API_URL=http://your-server-ip-or-domain:8000/api

# NEXT_PUBLIC_SSO_URL: Redirection URL pointing to the deployed Central SSO Login portal.
NEXT_PUBLIC_SSO_URL=http://your-sso-server-ip-or-domain:5001/login
