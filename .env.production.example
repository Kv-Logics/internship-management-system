# NITT Internship Management System - Production Environment Variables
# Copy this file to `.env.production` before copying it to your server.

# PostgreSQL Database Settings
POSTGRES_USER=nitt_admin
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=ims_production
DATABASE_URL=postgresql+asyncpg://nitt_admin:your_secure_db_password_here@db:5432/ims_production

# Security & Authentication
# Generate secure keys using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secure_secret_key_here
JWT_ACCESS_SECRET=your_secure_jwt_access_secret_here
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Primary System Administrator Fallback
ADMIN_USERNAME=admin@nitt.edu
ADMIN_PASSWORD=your_secure_admin_password_here

# Frontend Application Settings
NEXT_PUBLIC_API_URL=/api

# Backend Application Settings
ENVIRONMENT=production
FRONTEND_URL=http://cdi.nitt.edu,https://cdi.nitt.edu,http://cdi.nitt.edu:6006,https://cdi.nitt.edu:6443

# Nginx/Docker Settings
DOMAIN_NAME=cdi.nitt.edu

# System Email Settings (Crucial for Initial Admin Login OTP)
# The system will use these credentials for sending OTPs if the database settings are empty.
SMTP_HOST=webmail.nitt.edu
SMTP_PORT=465
SMTP_USERNAME=noreplycdi
SMTP_PASSWORD='Authentication2026*'
SMTP_SECURE=ssl

# Note: Once logged in, the Admin can override these or specify a different certificate-sending email via the Settings Portal.
