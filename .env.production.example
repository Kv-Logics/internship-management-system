# NITT Internship Management System - Production Environment Variables
# Copy this file to `.env.production` before copying it to your server.

# PostgreSQL Database Settings
POSTGRES_USER=nitt_admin
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=ims_production

# Backend Application Settings
# Generate a secure key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_secure_jwt_secret_key_here
ENVIRONMENT=production
CORS_ORIGINS=http://cdi.nitt.edu,https://cdi.nitt.edu

# Nginx/Docker Settings
DOMAIN_NAME=cdi.nitt.edu

# Note on SMTP Settings:
# You can configure SMTP mail server credentials (e.g., host, port, webmail username, and password)
# securely inside the Admin Settings Portal in the UI after you deploy, 
# or you can add them to the database initialization scripts if you prefer.
