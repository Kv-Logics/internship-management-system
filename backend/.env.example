# Database - Full PostgreSQL connection string (change for your deployment server)
DATABASE_URL=postgresql://user:password@host:5432/internship_management

# Central NITT Auth - JWT_ACCESS_SECRET must match nitt_auth_final/backend/.env
JWT_ACCESS_SECRET=your_jwt_access_secret_key_2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email (for certificate delivery)
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# CORS - comma-separated allowed frontend origins
FRONTEND_URL=http://localhost:3000
