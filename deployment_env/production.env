# ==============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# Location: deployment_env/production.env
# ==============================================================================

# ------------------------------------------------------------------------------
# SECTION 1: WHAT YOU CAN CONFIGURE AND DECIDE RIGHT NOW
# ------------------------------------------------------------------------------

# Database User & Database Name
POSTGRES_USER=ims_admin
POSTGRES_DB=internship_management

# Database Password (Choose a strong password now)
POSTGRES_PASSWORD=your_custom_production_db_password

# Database connection string (Matches POSTGRES_USER and POSTGRES_PASSWORD)
# Note: Use "db" as host if using Docker Compose, or your DB IP if running standalone.
DATABASE_URL=postgresql+asyncpg://ims_admin:your_custom_production_db_password@db:5432/internship_management

# Backend Secret Key (Generate a random 32-byte hex string now)
# You can generate this by running: openssl rand -hex 32
SECRET_KEY=paste_your_generated_hex_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Primary Fallback Administrator Account
# Set the primary admin email and a secure password for first login
ADMIN_USERNAME=114123003@nitt.edu
ADMIN_PASSWORD=your_secure_fallback_admin_password


# ------------------------------------------------------------------------------
# SECTION 2: WHAT TO CONFIGURE ONLY AT DEPLOYMENT TIME
# ------------------------------------------------------------------------------

# Central SSO Decryption Keys
# These MUST match the secrets configured in the deployed NITT SSO Authentication Server.
# Copy these two keys from the deployed SSO configuration at deployment time.
JWT_ACCESS_SECRET=get_this_from_deployed_sso_config
JWT_REFRESH_SECRET=get_this_from_deployed_sso_config

# Production Domain URLs & IP Endpoints
# Update these with the actual IP address or Domain Name of your production server.
FRONTEND_URL=https://your-production-domain.nitt.edu
NEXT_PUBLIC_API_URL=https://your-production-api-domain.nitt.edu/api
NEXT_PUBLIC_SSO_URL=https://your-deployed-sso-domain.nitt.edu/login
